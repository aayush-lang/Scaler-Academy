    <!-- Formula bar -->
    <div class="formula-bar">
      <strong>Final Payout</strong>
      <span class="formula-sep">=</span>
      <span>Net Sales</span>
      <span class="formula-sep">×</span>
      <span>Rate after all 6 steps</span>
      <span class="formula-sep">|</span>
      <span>Each deduction stacks on the prior rate</span>
      <span class="formula-sep">|</span>
      <span>Assessed every 6 months</span>
    </div>
  </div><!-- end rules-section -->


  <!-- ── SECTION 2: CALCULATOR ─────────────────────── -->
  <div class="calc-section">
    <div class="section-label">Commission Calculator</div>

    <div class="calc-grid">

      <!-- Inputs -->
      <div class="calc-inputs">
        <div class="calc-inputs-header">Enter Actuals</div>
        <div class="calc-inputs-body">

          <div class="input-group">
            <label>Net Sales (count)</label>
            <input type="number" id="inp-sales" placeholder="e.g. 175" min="0">
            <div class="input-hint">Closed sales after refunds are deducted</div>
          </div>

          <div class="input-group">
            <label>Base Amount per Sale (₹)</label>
            <input type="number" id="inp-base" placeholder="e.g. 1500" min="0">
          </div>

          <div class="input-group">
            <label>Refund % (actual)</label>
            <div class="input-row">
              <input type="number" id="inp-refund" placeholder="e.g. 22" min="0" max="100" style="flex:1">
              <span style="display:flex;align-items:center;padding:0 8px;color:var(--gray);font-size:0.85rem;font-family:'DM Mono',monospace">%</span>
