          <!-- Process Amber -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><input class="inline-input amber-inp" id="p-a-cond1" type="text" value="65%" style="width:38px"/> <span class="cond-prefix">to</span> <input class="inline-input amber-inp" id="p-a-cond2" type="text" value="80%" style="width:38px"/></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input amber-inp deduct-inp" id="p-a-ded" type="text" value="8%" /></div>
          </td>
        </tr>

        <!-- RED ROW -->
        <tr class="data-row red-row">
          <td class="td-zone red-zone"><span class="zone-badge red">● Red</span><div class="zone-hint">Steep deduction</div></td>

          <!-- Base -->
          <td class="td-cell">
            <div class="cell-label">Applied to</div>
            <div class="cell-val" style="color:var(--gray);font-size:0.65rem">Prev step rate</div>
          </td>

          <!-- Refund Red -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Above </span><input class="inline-input red-inp" id="r-r-cond" type="text" value="20%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input red-inp deduct-inp" id="r-r-ded" type="text" value="25%" /></div>
          </td>

          <!-- Attrition Red -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Above </span><input class="inline-input red-inp" id="a-r-cond" type="text" value="15%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input red-inp deduct-inp" id="a-r-ded" type="text" value="20%" /></div>
          </td>

          <!-- Forecast Red -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Below </span><input class="inline-input red-inp" id="f-r-cond" type="text" value="65%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input red-inp deduct-inp" id="f-r-ded" type="text" value="20%" /></div>
          </td>

          <!-- Leads Red -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Below </span><input class="inline-input red-inp" id="l-r-cond" type="text" value="60%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input red-inp deduct-inp" id="l-r-ded" type="text" value="18%" /></div>
          </td>

          <!-- Process Red -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Below </span><input class="inline-input red-inp" id="p-r-cond" type="text" value="65%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input red-inp deduct-inp" id="p-r-ded" type="text" value="18%" /></div>
