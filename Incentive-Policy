              <span style="display:flex;align-items:center;padding:0 8px;color:var(--gray);font-size:0.85rem;font-family:'DM Mono',monospace">%</span>
            </div>
          </div>

          <div class="input-group">
            <label>Forecast Accuracy % (actual)</label>
            <div class="input-row">
              <input type="number" id="inp-forecast" placeholder="e.g. 80" min="0" max="100" style="flex:1">
              <span style="display:flex;align-items:center;padding:0 8px;color:var(--gray);font-size:0.85rem;font-family:'DM Mono',monospace">%</span>
            </div>
          </div>

          <div class="input-group">
            <label>Lead Utilisation % (actual)</label>
            <div class="input-row">
              <input type="number" id="inp-leads" placeholder="e.g. 68" min="0" max="100" style="flex:1">
              <span style="display:flex;align-items:center;padding:0 8px;color:var(--gray);font-size:0.85rem;font-family:'DM Mono',monospace">%</span>
            </div>
          </div>

          <div class="input-group">
            <label>Process Management Score % (actual)</label>
            <div class="input-row">
              <input type="number" id="inp-process" placeholder="e.g. 85" min="0" max="100" style="flex:1">
              <span style="display:flex;align-items:center;padding:0 8px;color:var(--gray);font-size:0.85rem;font-family:'DM Mono',monospace">%</span>
            </div>
          </div>

          <button class="calc-btn" onclick="calculate()">Calculate Commission →</button>

        </div>
      </div>

      <!-- Result -->
      <div class="calc-result">
        <div class="calc-result-header">Step-by-Step Breakdown</div>
        <div class="calc-result-body">
          <div class="result-empty" id="result-empty">
            <div class="icon">⟶</div>
            Enter your actuals and click Calculate
          </div>
          <div id="result-content" style="display:none"></div>
        </div>
      </div>

    </div>
