<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SM & AGM Commission Policy</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy:    #1A2744;
    --navy2:   #243258;
    --navy3:   #0F1A30;
    --gold:    #E8A020;
    --gold2:   #F5C842;
    --red:     #C0392B;
    --green:   #1A7A52;
    --amber:   #C96A00;
    --light:   #F4F6FA;
    --white:   #FFFFFF;
    --gray:    #8492A6;
    --border:  #DEE4EF;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--navy3);
    color: var(--white);
    min-height: 100vh;
  }

  /* ── HEADER ───────────────────────────────────────── */
  .header {
    background: var(--navy);
    border-bottom: 3px solid var(--gold);
    padding: 14px 32px 12px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }
  .header-left h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.7rem;
    color: var(--white);
    line-height: 1.1;
    letter-spacing: -0.5px;
  }
  .header-left h1 span { color: var(--gold); }
  .header-meta {
    display: flex;
    gap: 16px;
    margin-top: 5px;
    flex-wrap: wrap;
  }
  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
    background: rgba(255,255,255,0.05);
    padding: 4px 10px;
    border-radius: 3px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .header-right {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--gold);
    text-align: right;
    line-height: 1.7;
    opacity: 0.8;
  }

  /* ── MAIN LAYOUT ──────────────────────────────────── */
  .main { max-width: 1400px; margin: 0 auto; padding: 16px 32px 32px; }

  /* ── SECTION TITLES ───────────────────────────────── */
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, rgba(232,160,32,0.3), transparent);
  }

  /* ── RULES TABLE — TRANSPOSED ───────────────────── */
  .rules-section { margin-bottom: 20px; }

  .rules-grid {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    overflow: hidden;
    table-layout: fixed;
  }

  /* Column headers */
  .rules-grid thead tr:first-child { background: var(--navy); border-bottom: 2px solid var(--gold); }
  .rules-grid thead th {
    padding: 9px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.07);
    white-space: nowrap;
  }
  .rules-grid thead th:last-child { border-right: none; }
  .rules-grid thead th.th-zone  { width: 90px; text-align: left; color: var(--gray); }
  .rules-grid thead th.th-base  { width: 100px; }
  .rules-grid thead th.th-crit  { /* equal share of remaining */ }

  /* Sub-header row */
  .rules-grid tr.sub-header { background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.06); }
  .rules-grid tr.sub-header td {
    padding: 3px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    color: rgba(255,255,255,0.3);
    text-align: center;
    border-right: 1px solid rgba(255,255,255,0.04);
  }
  .rules-grid tr.sub-header td:last-child { border-right: none; }

  /* Data rows */
  .rules-grid tr.data-row td { border-right: 1px solid rgba(255,255,255,0.05); vertical-align: top; }
  .rules-grid tr.data-row td:last-child { border-right: none; }
  .rules-grid tr.data-row { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .rules-grid tr.data-row:last-child { border-bottom: none; }

  .rules-grid tr.green-row { background: rgba(26,122,82,0.07); }
  .rules-grid tr.amber-row { background: rgba(201,106,0,0.07); }
  .rules-grid tr.red-row   { background: rgba(192,57,43,0.07); }

  /* Zone label cell */
  .td-zone {
    padding: 12px 10px;
    vertical-align: middle !important;
    text-align: left;
  }
  .zone-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    display: block;
    margin-bottom: 3px;
  }
  .zone-badge.green { color: #4ADE80; }
  .zone-badge.amber { color: #FBB040; }
  .zone-badge.red   { color: #F87171; }
  .zone-hint {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    color: rgba(255,255,255,0.3);
  }
  .green-zone { border-left: 3px solid #4ADE80; }
  .amber-zone { border-left: 3px solid #FBB040; }
  .red-zone   { border-left: 3px solid #F87171; }

  /* Content cells */
  .td-cell { padding: 8px 12px; }
  .cell-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 3px;
  }
  .cell-val {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--white);
  }
  .cell-val.gold  { color: var(--gold2); }
  .cell-val.green { color: #4ADE80; }

  .cell-editable { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
  .cond-prefix {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
  }

  /* Editable inputs inside the table */
  .inline-input {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 3px;
    padding: 2px 6px;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--white);
    width: 52px;
    text-align: center;
    outline: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .inline-input:focus { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.1); }
  .inline-input.green-inp { color: #4ADE80; border-color: rgba(74,222,128,0.25); background: rgba(26,122,82,0.1); }
  .inline-input.green-inp:focus { border-color: #4ADE80; }
  .inline-input.amber-inp { color: #FBB040; border-color: rgba(251,176,64,0.25); background: rgba(201,106,0,0.1); }
  .inline-input.amber-inp:focus { border-color: #FBB040; }
  .inline-input.red-inp   { color: #F87171; border-color: rgba(248,113,113,0.25); background: rgba(192,57,43,0.1); }
  .inline-input.red-inp:focus { border-color: #F87171; }
  .deduct-inp { width: 52px; }

  /* ── FORMULA BAR ──────────────────────────────────── */
  .formula-bar {
    background: linear-gradient(135deg, var(--navy), #1E3A5F);
    border: 1px solid var(--gold);
    border-radius: 6px;
    padding: 9px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .formula-bar span {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.6);
  }
  .formula-bar strong {
    font-family: 'DM Mono', monospace;
    font-size: 0.78rem;
    color: var(--gold);
  }
  .formula-sep { color: rgba(255,255,255,0.25) !important; }

  /* ── CALCULATOR ───────────────────────────────────── */
  .calc-section { }

  .calc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .calc-inputs {
    background: var(--navy);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
  }
  .calc-inputs-header {
    background: var(--navy2);
    padding: 16px 24px;
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .calc-inputs-body { padding: 24px; display: flex; flex-direction: column; gap: 18px; }

  .input-group label {
    display: block;
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 7px;
  }
  .input-row { display: flex; gap: 10px; }
  .input-row input, .input-group input, .input-group select {
    width: 100%;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    padding: 10px 14px;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    color: var(--white);
    transition: border-color 0.2s, background 0.2s;
    outline: none;
  }
  .input-row input:focus, .input-group input:focus, .input-group select:focus {
    border-color: var(--gold);
    background: rgba(232,160,32,0.05);
  }
  .input-group select option { background: var(--navy); }
  .input-hint {
    font-size: 0.7rem;
    color: var(--gray);
    margin-top: 5px;
    font-family: 'DM Mono', monospace;
  }

  .calc-btn {
    width: 100%;
    background: var(--gold);
    color: var(--navy);
    border: none;
    border-radius: 6px;
    padding: 13px;
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: background 0.2s, transform 0.1s;
    margin-top: 6px;
  }
  .calc-btn:hover { background: var(--gold2); transform: translateY(-1px); }
  .calc-btn:active { transform: translateY(0); }

  /* ── RESULT PANEL ─────────────────────────────────── */
  .calc-result {
    background: var(--navy);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
  }
  .calc-result-header {
    background: var(--navy2);
    padding: 16px 24px;
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .calc-result-body { padding: 24px; }

  .result-empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--gray);
    font-size: 0.85rem;
    font-family: 'DM Mono', monospace;
  }
  .result-empty .icon { font-size: 2rem; margin-bottom: 10px; opacity: 0.4; }

  .result-steps { display: flex; flex-direction: column; gap: 0; }

  .result-step {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    gap: 12px;
  }
  .result-step:last-child { border-bottom: none; }

  .result-step-left { display: flex; align-items: center; gap: 10px; flex: 1; }
  .result-step-icon {
    width: 26px; height: 26px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem;
    font-family: 'DM Mono', monospace;
    font-weight: 700;
    flex-shrink: 0;
  }
  .result-step-icon.green { background: rgba(26,122,82,0.2); color: #4ADE80; }
  .result-step-icon.amber { background: rgba(201,106,0,0.2); color: #FBB040; }
  .result-step-icon.red   { background: rgba(192,57,43,0.2); color: #F87171; }
  .result-step-icon.base  { background: rgba(232,160,32,0.2); color: var(--gold); }

  .result-step-name { font-size: 0.8rem; color: rgba(255,255,255,0.7); }
  .result-step-condition { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--gray); }

  .result-step-right { text-align: right; }
  .result-step-rate {
    font-family: 'DM Mono', monospace;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--white);
  }
  .result-step-deduct {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--gray);
    margin-top: 1px;
  }
  .result-step-deduct.hit { color: #F87171; }
  .result-step-deduct.amber-hit { color: #FBB040; }

  .result-divider {
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    margin: 12px 0;
    opacity: 0.4;
  }

  .result-final {
    background: linear-gradient(135deg, rgba(232,160,32,0.1), rgba(232,160,32,0.05));
    border: 1px solid rgba(232,160,32,0.25);
    border-radius: 8px;
    padding: 20px;
    margin-top: 12px;
  }
  .result-final-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }
  .result-final-amount {
    font-family: 'DM Serif Display', serif;
    font-size: 2.4rem;
    color: var(--white);
    line-height: 1;
  }
  .result-final-amount span { color: var(--gold); }
  .result-final-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--gray);
    margin-top: 5px;
    line-height: 1.6;
  }
  .result-final-sub strong { color: rgba(255,255,255,0.6); }

  /* ── FOOTER ───────────────────────────────────────── */
  .footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 20px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--gray);
    opacity: 0.6;
  }

  /* ── ANIMATIONS ───────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .rules-section { animation: fadeUp 0.4s ease both; }
  .calc-section  { animation: fadeUp 0.4s 0.15s ease both; }

  @keyframes resultIn {
    from { opacity: 0; transform: translateX(8px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .result-steps { animation: resultIn 0.3s ease both; }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 900px) {
    .main { padding: 24px 20px 40px; }
    .header { padding: 20px; flex-direction: column; align-items: flex-start; }
    .calc-grid { grid-template-columns: 1fr; }
    /* responsive handled by table layout */
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-left">
    <h1>SM & AGM <span>Commission Policy</span></h1>
    <div class="header-meta">
      <span class="tag">FY 2025–26</span>
      <span class="tag">Sales Leadership</span>
      <span class="tag">Confidential</span>
      <span class="tag">6-Month Cycle</span>
    </div>
  </div>
  <div class="header-right">
    All criteria evaluated independently<br>
    Deductions stack on prior rate
  </div>
</div>

<div class="main">

  <!-- ── SECTION 1: RULES ──────────────────────────── -->
  <div class="rules-section">
    <div class="section-label">Policy Rules &nbsp;<span style="font-size:0.6rem;opacity:0.5;letter-spacing:0.05em;text-transform:none;font-family:'DM Mono',monospace">— edit condition thresholds &amp; deductions directly in the table</span></div>

    <table class="rules-grid" id="rules-table">
      <thead>
        <tr>
          <th class="th-zone">Zone</th>
          <th class="th-base">Base Rate</th>
          <th class="th-crit">Refund %</th>
          <th class="th-crit">Attrition %</th>
          <th class="th-crit">Forecast Accuracy</th>
          <th class="th-crit">Lead Utilisation</th>
          <th class="th-crit">Process Management</th>
        </tr>
        <tr class="sub-header">
          <td></td>
          <td class="sub">Net sales × base</td>
          <td class="sub">Lower is better · Step 2</td>
          <td class="sub">Lower is better · Step 3</td>
          <td class="sub">Higher is better · Step 4</td>
          <td class="sub">Higher is better · Step 5</td>
          <td class="sub">Higher is better · Step 6</td>
        </tr>
      </thead>
      <tbody>

        <!-- GREEN ROW -->
        <tr class="data-row green-row">
          <td class="td-zone green-zone"><span class="zone-badge green">● Green</span><div class="zone-hint">No deduction</div></td>

          <!-- Base -->
          <td class="td-cell">
            <div class="cell-label">Amount / Sale</div>
            <div class="cell-val gold">₹ Y</div>
          </td>

          <!-- Refund Green -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Below </span><input class="inline-input green-inp" id="r-g-cond" type="text" value="10%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-val green">No deduction</div>
          </td>

          <!-- Attrition Green -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Below </span><input class="inline-input green-inp" id="a-g-cond" type="text" value="10%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-val green">No deduction</div>
          </td>

          <!-- Forecast Green -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Above </span><input class="inline-input green-inp" id="f-g-cond" type="text" value="80%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-val green">No deduction</div>
          </td>

          <!-- Leads Green -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Above </span><input class="inline-input green-inp" id="l-g-cond" type="text" value="75%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-val green">No deduction</div>
          </td>

          <!-- Process Green -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><span class="cond-prefix">Above </span><input class="inline-input green-inp" id="p-g-cond" type="text" value="80%" /></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-val green">No deduction</div>
          </td>
        </tr>

        <!-- AMBER ROW -->
        <tr class="data-row amber-row">
          <td class="td-zone amber-zone"><span class="zone-badge amber">● Amber</span><div class="zone-hint">Partial deduction</div></td>

          <!-- Base -->
          <td class="td-cell">
            <div class="cell-label">Applied to</div>
            <div class="cell-val" style="color:var(--gray);font-size:0.65rem">Base rate Y</div>
          </td>

          <!-- Refund Amber -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><input class="inline-input amber-inp" id="r-a-cond1" type="text" value="10%" style="width:38px"/> <span class="cond-prefix">to</span> <input class="inline-input amber-inp" id="r-a-cond2" type="text" value="20%" style="width:38px"/></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input amber-inp deduct-inp" id="r-a-ded" type="text" value="10%" /></div>
          </td>

          <!-- Attrition Amber -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><input class="inline-input amber-inp" id="a-a-cond1" type="text" value="10%" style="width:38px"/> <span class="cond-prefix">to</span> <input class="inline-input amber-inp" id="a-a-cond2" type="text" value="15%" style="width:38px"/></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input amber-inp deduct-inp" id="a-a-ded" type="text" value="10%" /></div>
          </td>

          <!-- Forecast Amber -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><input class="inline-input amber-inp" id="f-a-cond1" type="text" value="65%" style="width:38px"/> <span class="cond-prefix">to</span> <input class="inline-input amber-inp" id="f-a-cond2" type="text" value="80%" style="width:38px"/></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
            <div class="cell-editable"><input class="inline-input amber-inp deduct-inp" id="f-a-ded" type="text" value="10%" /></div>
          </td>

          <!-- Leads Amber -->
          <td class="td-cell">
            <div class="cell-label">Condition</div>
            <div class="cell-editable"><input class="inline-input amber-inp" id="l-a-cond1" type="text" value="60%" style="width:38px"/> <span class="cond-prefix">to</span> <input class="inline-input amber-inp" id="l-a-cond2" type="text" value="75%" style="width:38px"/></div>
            <div class="cell-label" style="margin-top:5px">Deduction</div>
