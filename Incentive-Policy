<div class="footer">
  <span>Confidential — Sales Leadership — FY 2025–26</span>
  <span>All thresholds marked ___ to be defined by leadership before rollout</span>
</div>

<script>
// ─── READ POLICY LIVE FROM TABLE INPUTS ──────────────────────
function parseP(id) { return parseFloat(document.getElementById(id).value) || 0; }

function getPolicyFromTable() {
  return {
    refund:    { lower_is_better: true,  green_thresh: parseP('r-g-cond'), amber_lo: parseP('r-a-cond1'), amber_hi: parseP('r-a-cond2'), mult_amber: 1 - parseP('r-a-ded')/100, mult_red: 1 - parseP('r-r-ded')/100, label: 'Refund %' },
    attrition: { lower_is_better: true,  green_thresh: parseP('a-g-cond'), amber_lo: parseP('a-a-cond1'), amber_hi: parseP('a-a-cond2'), mult_amber: 1 - parseP('a-a-ded')/100, mult_red: 1 - parseP('a-r-ded')/100, label: 'Attrition %' },
    forecast:  { lower_is_better: false, green_thresh: parseP('f-g-cond'), amber_lo: parseP('f-a-cond1'), amber_hi: parseP('f-a-cond2'), mult_amber: 1 - parseP('f-a-ded')/100, mult_red: 1 - parseP('f-r-ded')/100, label: 'Forecast Accuracy' },
    leads:     { lower_is_better: false, green_thresh: parseP('l-g-cond'), amber_lo: parseP('l-a-cond1'), amber_hi: parseP('l-a-cond2'), mult_amber: 1 - parseP('l-a-ded')/100, mult_red: 1 - parseP('l-r-ded')/100, label: 'Lead Utilisation' },
    process:   { lower_is_better: false, green_thresh: parseP('p-g-cond'), amber_lo: parseP('p-a-cond1'), amber_hi: parseP('p-a-cond2'), mult_amber: 1 - parseP('p-a-ded')/100, mult_red: 1 - parseP('p-r-ded')/100, label: 'Process Management' },
  };
}

// Helper: strip % from input values for display purposes
document.querySelectorAll && document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.inline-input').forEach(inp => {
    inp.addEventListener('input', () => {
      inp.value = inp.value.replace(/[^0-9.%]/g,'');
    });
  });
});

function getZone(p, value) {
  if (p.lower_is_better) {
    if (value < p.green_thresh) return 'green';
    if (value <= p.amber_hi)    return 'amber';
    return 'red';
  } else {
    if (value >= p.green_thresh) return 'green';
    if (value >= p.amber_lo)     return 'amber';
    return 'red';
  }
}

function getMultiplier(p, zone) {
  if (zone === 'green') return 1.00;
  if (zone === 'amber') return p.mult_amber;
  return p.mult_red;
}

function conditionText(p, value, zone) {
  if (p.lower_is_better) {
    if (zone === 'green') return `${value}% — below ${p.green_thresh}% ✓`;
    if (zone === 'amber') return `${value}% — ${p.amber_lo}–${p.amber_hi}%`;
    return `${value}% — above ${p.amber_hi}%`;
  } else {
    if (zone === 'green') return `${value}% — above ${p.green_thresh}% ✓`;
    if (zone === 'amber') return `${value}% — ${p.amber_lo}–${p.amber_hi}%`;
    return `${value}% — below ${p.amber_lo}%`;
  }
}

function fmt(n) {
  return '₹' + Math.round(n).toLocaleString('en-IN');
}

function calculate() {
  const sales    = parseFloat(document.getElementById('inp-sales').value);
  const base     = parseFloat(document.getElementById('inp-base').value);
  const refund   = parseFloat(document.getElementById('inp-refund').value);
  const attrition= parseFloat(document.getElementById('inp-attrition').value);
  const forecast = parseFloat(document.getElementById('inp-forecast').value);
  const leads    = parseFloat(document.getElementById('inp-leads').value);
  const process  = parseFloat(document.getElementById('inp-process').value);

  if ([sales, base, refund, attrition, forecast, leads, process].some(isNaN)) {
    alert('Please fill in all fields before calculating.');
    return;
  }

  // Step-by-step calculation
  const steps = [];
  let rate = base;

  steps.push({
    num: '1', label: 'Base Rate', condition: `${sales} sales × ${fmt(base)}`,
    zone: 'base', rate, multiplier: null, deduction: null
  });

  const POLICY = getPolicyFromTable();
  const checks = [
    { key: 'refund',    val: refund },
    { key: 'attrition', val: attrition },
    { key: 'forecast',  val: forecast },
    { key: 'leads',     val: leads },
    { key: 'process',   val: process },
  ];

  checks.forEach((c, i) => {
    const p    = POLICY[c.key];
    const zone = getZone(p, c.val);
    const mult = getMultiplier(p, zone);
    const prevRate = rate;
    rate = rate * mult;
    const dedPct = Math.round((1 - mult) * 100);
    steps.push({
      num: String(i + 2),
      label: p.label,
      condition: conditionText(p, c.val, zone),
      zone,
      rate,
      multiplier: mult,
      deduction: dedPct > 0 ? `−${dedPct}% (${fmt(prevRate)} → ${fmt(rate)})` : null,
      deductionClass: dedPct > 0 ? (zone === 'amber' ? 'amber-hit' : 'hit') : '',
    });
  });

  const totalPayout = sales * rate;
  const maxPayout = sales * base;
  const effectivePct = Math.round((rate / base) * 100);

  // Render
  document.getElementById('result-empty').style.display = 'none';
  const el = document.getElementById('result-content');
  el.style.display = 'block';

  el.innerHTML = `
    <div class="result-steps">
      ${steps.map(s => `
        <div class="result-step">
          <div class="result-step-left">
            <div class="result-step-icon ${s.zone}">${s.num}</div>
            <div>
              <div class="result-step-name">${s.label}</div>
              <div class="result-step-condition">${s.condition}</div>
            </div>
          </div>
          <div class="result-step-right">
            <div class="result-step-rate">${fmt(s.rate)}<span style="font-size:0.7rem;color:var(--gray)"> /sale</span></div>
            ${s.deduction
              ? `<div class="result-step-deduct ${s.deductionClass}">${s.deduction}</div>`
              : `<div class="result-step-deduct" style="color:var(--green);opacity:0.7">No deduction</div>`
            }
          </div>
        </div>
      `).join('')}
    </div>
    <div class="result-divider"></div>
    <div class="result-final">
      <div class="result-final-label">Total Commission Payout</div>
      <div class="result-final-amount">${fmt(totalPayout)}</div>
      <div class="result-final-sub">
        <strong>${sales}</strong> net sales ×
        <strong>${fmt(rate)}</strong> final rate per sale<br>
        Effective rate: <strong>${effectivePct}%</strong> of base rate
        &nbsp;|&nbsp; Max possible: <strong>${fmt(maxPayout)}</strong>
        &nbsp;|&nbsp; Retained: <strong>${fmt(totalPayout)}</strong>
      </div>
    </div>
  `;
}

// Allow Enter key to trigger calculate
document.addEventListener('keydown', e => {
  if (e.key === 'Enter') calculate();
});
</script>
</body>
